---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteData, socialLinks, contactInfo } from '../data/siteData';
import MapImage from "@assets/photo-1517487881594-2787fef5ebf7.jpg"
---

<Layout title={`Contact Us - ${siteData.name}`} description="Get in touch with us to start your fitness journey">
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">Contáctanos</h1>
        <p class="text-xl text-gray-300">
          Estamos listos para comenzar a trabajar en tu sitio web
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info & Form -->
  <section class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <!-- Contact Information -->
        <div>
          <h2 class="text-3xl font-bold text-white mb-8">Déjanos un mensaje</h2>
          
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Response Time Section -->
  <section class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="bg-slate-900 p-8 rounded-xl border border-slate-700">
          <div class="flex items-start gap-6">
            <div class="bg-orange-500/10 p-4 rounded-lg shrink-0">
              <i class="ri-time-line text-4xl text-lime-500"></i>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-white mb-3"> ¿Cómo te atendemos?</h3>
              <p class="text-gray-300 mb-4 leading-relaxed">
                Tenemos el compromiso de atender inmediatamente a todos nuestros clientes:
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <i class="ri-checkbox-circle-fill text-lime-500 text-xl mt-0.5"></i>
                  <div>
                    <span class="text-white font-semibold">Contestamos al día siguiente:</span>
                    <span class="text-gray-300"> Respondemos en un lapso de 24 horas en días laborales.</span>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <i class="ri-checkbox-circle-fill text-lime-500 text-xl mt-0.5"></i>
                  <div>
                    <span class="text-white font-semibold">Manda un mensaje desde tu mail:</span>
                    <span class="text-gray-300"> Si lo prefieres manda un email a: hola@cultivodigital.com</span>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <i class="ri-checkbox-circle-fill text-lime-500 text-xl mt-0.5"></i>
                  <div>
                    <span class="text-white font-semibold">Consultas sin costo:</span>
                    <span class="text-gray-300"> Haz todas las consultas y despeja todas tus dudas sin límites.</span>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <i class="ri-checkbox-circle-fill text-lime-500 text-xl mt-0.5"></i>
                  <div>
                    <span class="text-white font-semibold">También atendemos por Whatsapp:</span>
                    <span class="text-gray-300"> Una vez establecido el primer contacto por email podemos seguir en el sistema de comunicación que prefieras.</span>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


</Layout>

