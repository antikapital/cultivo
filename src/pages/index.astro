---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Statistics from '../components/Statistics.astro';
import Features from '../components/Features.astro';
import Facilities from '../components/Facilities.astro';
import Classes from '../components/Classes.astro';
import ClassSchedule from '../components/ClassSchedule.astro';
import PricingPlans from '../components/PricingPlans.astro';
import SuccessStories from '../components/SuccessStories.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import { siteData } from '../data/siteData';
---

<Layout title={`${siteData.name} - ${siteData.tagline}`} description={siteData.description}>
  <Hero />
  <Features />

    <!-- Mission Section -->
  <section id="nosotros" class="py-20 bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-white mb-8 text-center">
          Sobre Nosotros
        </h2>
        <div class="prose prose-invert max-w-none">
          <p class="text-xl text-gray-300 mb-6">
            En {siteData.name} sabemos que un gran sitio web es inútil si no comunica el mensaje correcto. Nuestro fundador integra años de experiencia en el desarrollo full-stack con una visión estratégica de la comunicación.

No somos una fábrica de sitios en serie. Somos un estudio boutique donde cada proyecto se planifica como una semilla: con cuidado, técnica y la visión de que, con la estrategia adecuada, todo negocio puede florecer en el entorno digital.
          </p>
        </div>
      </div>
    </div>
  </section>

<div class="container bg-slate-900 mx-auto w-full h-full">
  <div class="relative wrap overflow-hidden p-10 h-full">
    <h2 class="text-4xl font-bold text-white mb-8 text-center">
          Nuestro proceso de Cultivo
    </h2>
    <div class="border-2-2 absolute border-opacity-20 border-gray-700 h-full border" style="left: 50%"></div>

    <!-- right timeline -->
    <div class="mb-8 flex justify-between items-center w-full right-timeline">
      <div class="order-1 w-5/12"></div>
      <div class="z-20 flex items-center order-1 bg-lime-600 shadow-xl w-8 h-8 rounded-full">
        <h1 class="mx-auto font-semibold text-lg text-white">1</h1>
      </div>
      <div class="order-1 bg-gray-200 rounded-lg shadow-xl w-5/12 px-6 py-4">
        <h3 class="mb-3 font-bold text-gray-800 lg:text-xl md:text-lg text-sm">Planificación</h3>
        <p class="text-sm leading-snug tracking-wide text-gray-900 text-opacity-100">
          Entendemos tu negocio y definimos la hoja de ruta.</p>
      </div>
    </div>

    <!-- left timeline -->
    <div class="mb-8 flex justify-between flex-row-reverse items-center w-full left-timeline">
      <div class="order-1 w-5/12"></div>
      <div class="z-20 flex items-center order-1 bg-lime-600 shadow-xl w-8 h-8 rounded-full">
        <h1 class="mx-auto text-white font-semibold text-lg">2</h1>
      </div>
      <div class="order-1 bg-lime-600 rounded-lg shadow-xl w-5/12 px-6 py-4">
        <h3 class="mb-3 font-bold text-white lg:text-xl md:text-lg text-sm">Desarrollo</h3>
        <p class="text-sm font-medium leading-snug tracking-wide text-white text-opacity-100">
          Construcción técnica con los estándares más altos.</p>
      </div>
    </div>
    
    <!-- right timeline -->
    <div class="mb-8 flex justify-between items-center w-full right-timeline">
      <div class="order-1 w-5/12"></div>
      <div class="z-20 flex items-center order-1 bg-lime-600 shadow-xl w-8 h-8 rounded-full">
        <h1 class="mx-auto font-semibold text-lg text-white">3</h1>
      </div>
      <div class="order-1 bg-gray-200 rounded-lg shadow-xl w-5/12 px-6 py-4">
        <h3 class="mb-3 font-bold text-gray-800 lg:text-xl md:text-lg text-sm">Optimización</h3>
        <p class="text-sm leading-snug tracking-wide text-gray-900 text-opacity-100">
          Refinamos SEO y contenido para el lanzamiento.</p>
      </div>
    </div>

    <!-- left timeline -->
    <div class="mb-8 flex justify-between flex-row-reverse items-center w-full left-timeline">
      <div class="order-1 w-5/12"></div>
      <div class="z-20 flex items-center order-1 bg-lime-600 shadow-xl w-8 h-8 rounded-full">
        <h1 class="mx-auto text-white font-semibold text-lg">4</h1>
      </div>
      <div class="order-1 bg-lime-600 rounded-lg shadow-xl w-5/12 px-6 py-4">
        <h3 class="mb-3 font-bold text-white lg:text-xl md:text-lg text-sm">Crecimiento</h3>
        <p class="text-sm font-medium leading-snug tracking-wide text-white text-opacity-100">
          Lanzamos campañas y medimos resultados para seguir escalando.</p>
      </div>
    </div>
  </div>
</div>  

  <!-- CTA Section -->
  <section class="py-20 bg-linear-to-r from-lime-500 to-lime-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Cultivo Digital
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Sembramos tecnología, cosechamos resultados
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-3 bg-white text-lime-600 hover:bg-slate-100 px-8 py-4 rounded-lg font-bold text-lg transition-all transform hover:scale-105 shadow-lg"
      >
        Comienza hoy mismo
        <i class="ri-arrow-right-line"></i>
      </a>
    </div>
  </section>
</Layout>
