---
---

<form class="bg-slate-900 p-8 rounded-xl border border-slate-700 space-y-6"
  action="https://formspree.io/f/xldnwplv"
  method="POST">

  <div>
    <label for="email" class="block text-white font-semibold mb-2">
      Email
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-orange-500 transition-colors"
      placeholder="nombre@example.com"
    />
  </div>

  <div>
    <label for="message" class="block text-white font-semibold mb-2">
      Tu mensaje
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-orange-500 transition-colors resize-none"
      placeholder="Cuéntanos un poso sobre tu proyecto..."
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full bg-lime-500 hover:bg-lime-600 text-white px-8 py-4 rounded-lg font-bold text-lg transition-all transform hover:scale-105 flex items-center justify-center gap-3"
  >
    Send Message
    <i class="ri-send-plane-line"></i>
  </button>
</form>

