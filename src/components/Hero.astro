---
import { Image } from "astro:assets";
import { siteData } from "@data/siteData";
import HeroImage from "@assets/photo-1534438327276-14e5300c3a48.jpg";
---

<section
  class="relative min-h-screen flex items-center justify-center bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 pt-20 overflow-hidden"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight"
        >
          {siteData.tagline}
        </h1>
        <p class="text-xl md:text-1xl text-gray-300 mb-8 leading-relaxed">
          {siteData.description}
        </p>
        <div
          class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center lg:justify-start mb-12"
        >
          <a
            href="/contact"
            class="bg-lime-600 hover:bg-lime-700 text-white px-8 py-4 rounded-lg font-bold text-lg transition-all transform inline-flex items-center justify-center gap-3"
          >
            Comienza tu proyecto hoy
            <i class="ri-arrow-right-line"></i>
          </a>
          <a
            href="/about"
            class="bg-transparent border-2 border-white text-white hover:bg-white hover:text-slate-900 px-8 py-4 rounded-lg font-bold text-lg transition-all inline-flex items-center justify-center gap-3"
          >
            Ver nuestra metodología
            <i class="ri-information-line"></i>
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <div class="text-4xl md:text-5xl font-bold text-lime-500 mb-2">
              100+
            </div>
            <div class="text-gray-300 text-sm md:text-base">Sitios creados</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-4xl md:text-5xl font-bold text-lime-500 mb-2">
              50+
            </div>
            <div class="text-gray-300 text-sm md:text-base">
              Estrategias exitosas
            </div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-4xl md:text-5xl font-bold text-lime-500 mb-2">
              1-10
            </div>
            <div class="text-gray-300 text-sm md:text-base">Posición en Google</div>
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="hidden lg:block">
        <div class="relative">
          <div
            class="aspect-square rounded-2xl overflow-hidden bg-slate-800 border-2 border-slate-700 shadow-2xl">
            <video autoplay loop muted playsinline class="w-full">
              <source
                src="https://cdn.midjourney.com/video/af35ebe5-2b29-4319-8a73-291227d4e828/3.mp4"
                type="video/mp4"
              />
              Your browser does not support the video tag.
            </video>
          </div>
          <div
            class="absolute -bottom-6 -left-6 bg-lime-400 p-6 rounded-xl shadow-xl"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-12 h-12 bg-white rounded-lg flex items-center justify-center"
              >
                <i class="ri-shield-check-fill text-2xl text-lime-500"></i>
              </div>
              <div>
                <div class="text-slate-800 font-bold text-lg">Garantía</div>
                <div class="text-black/80 text-sm">En resultados proyectados</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div
    class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce hidden lg:block"
  >
    <i class="ri-arrow-down-line text-2xl text-white"></i>
  </div>
</section>
