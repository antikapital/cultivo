---
import { siteData, navigation, socialLinks, contactInfo } from '../data/siteData';
---

<footer class="bg-slate-900 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">Menú</h4>
        <ul class="space-y-2">
          {navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-gray-400 hover:text-lime-500 transition-colors"
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

            <!-- About Section -->
      <div>
        <h3 class="text-2xl font-bold text-white mb-4">{siteData.name}</h3>
        <p class="text-gray-400 mb-4">{siteData.description}</p>
      </div>

    </div>

    <div class="border-t border-slate-800 mt-8 pt-8 text-center text-gray-400">
      <p>&copy; {new Date().getFullYear()} {siteData.name}. All rights reserved.</p>
    </div>
  </div>
</footer>

